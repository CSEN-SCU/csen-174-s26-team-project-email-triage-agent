# Copy to `.env.local` in this directory (Next.js loads it automatically). Do not commit `.env.local`.

# Required — signs NextAuth JWT session cookies. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Optional — defaults work for local dev on port 3000
# NEXTAUTH_URL=http://localhost:3000

# Optional — FastAPI triage API (defaults to http://127.0.0.1:8000)
# NEXT_PUBLIC_TRIAGE_API_BASE_URL=http://127.0.0.1:8000
