# Copy to `.env` and fill in values. See prototypes/ethan/frontend/README.md for run steps.

# Next.js / NextAuth — for Next.js, copy these into prototypes/ethan/frontend/.env.local (not only this file)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# FastAPI backend (`prototypes/ethan/backend`) — copy these into `backend/.env` when running uvicorn from that folder
# DATABASE_URL=sqlite:///./ethan_triage.db
# CORS_ORIGINS=http://localhost:3000
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Next.js inbox → API (`prototypes/ethan/frontend/.env.local`)
# NEXT_PUBLIC_TRIAGE_API_BASE_URL=http://127.0.0.1:8000

# Optional: other LLM providers (not wired in this prototype backend yet)
# ANTHROPIC_API_KEY=
