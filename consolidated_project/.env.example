# Copy this file to `.env` in the same directory as docker-compose.yml.
# `docker compose up` will load these into the backend & frontend containers.

# --- Backend (FastAPI) -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
TRIAGE_MODEL=claude-sonnet-4-6
CLASSIFY_MODEL=claude-haiku-4-5-20251001
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js / NextAuth) ------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me
# Google OAuth client (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000
