# Required: secret used by NextAuth to sign the session cookie / JWT.
# Generate with: `openssl rand -base64 32`
AUTH_SECRET=replace-me-with-32-bytes-base64

# Google OAuth 2.0 client. Create at:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (must match exactly):
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Trust the host when running behind a proxy / non-default URL.
AUTH_TRUST_HOST=true

# Where the Next.js proxy forwards /api/* requests.
BACKEND_URL=http://localhost:8000
